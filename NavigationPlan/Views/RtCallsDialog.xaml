<Window x:Class="NavigationPlan.Views.RtCallsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RT Calls"
        Width="660" Height="720"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Copy to Clipboard" Click="CopyButton_Click"
                    Width="140" Margin="0,0,8,0"/>
            <Button Content="Close" IsCancel="True" Width="80"
                    Background="#FF3F3F3F" BorderBrush="#FF3F3F3F"/>
        </StackPanel>
        <TextBox x:Name="CallsTextBox"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"/>
    </DockPanel>
</Window>
