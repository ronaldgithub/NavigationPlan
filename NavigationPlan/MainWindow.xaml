<Window x:Class="NavigationPlan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Icon="NavigationPlan.ico"
        Title="Navigation Plan — Flight School Teuge"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <DockPanel LastChildFill="True">

        <!-- ====== Bottom: Nav Plan DataGrid ====== -->
        <Border DockPanel.Dock="Bottom" Height="250"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <DataGrid x:Name="NavPlanGrid"
                      ItemsSource="{Binding NavLegs}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Waypoint" Binding="{Binding WaypointName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Freq"     Binding="{Binding Frequency}"    Width="70"/>
                    <DataGridTextColumn Header="Level"    Binding="{Binding Level}"        Width="55" IsReadOnly="True"/>
                    <DataGridTextColumn Header="TAS"      Binding="{Binding Tas}"          Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="TT"       Binding="{Binding TrueTrack, StringFormat=000}"   Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="TH"       Binding="{Binding TrueHeading, StringFormat=000}" Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="WCA"      Binding="{Binding Wca}"           Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="MH"       Binding="{Binding MagneticHeading, StringFormat=000}" Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="GS"       Binding="{Binding GroundSpeed}"  Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Dist"     Binding="{Binding DistanceNm, StringFormat=F1}"  Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Time"     Binding="{Binding TimeMin}"      Width="45" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ETA"      Binding="{Binding Eta}"          Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ATA"      Binding="{Binding Ata}"          Width="50"/>
                    <DataGridTextColumn Header="Remarks"  Binding="{Binding Remarks}"      Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ====== Top: Left Panel + Map ====== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource BackgroundBrush}">
                <StackPanel Margin="8">

                    <!-- Aircraft -->
                    <GroupBox Header="Aircraft">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Reg:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding Registration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="Type:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding AircraftType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="Pilot:"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding Pilot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </GroupBox>

                    <!-- Flight -->
                    <GroupBox Header="Flight">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="From:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding From, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="To:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="Alternate:"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding Alternate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="3" Grid.Column="0" Content="Dep. Time:"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding DepartureTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Format: HH:mm (e.g. 10:00)"/>
                        </Grid>
                    </GroupBox>

                    <!-- Wind -->
                    <GroupBox Header="Wind &amp; Pressure">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Dir (°):"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding WindDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Direction FROM which wind blows (0–360°)"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="Speed (kt):"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding WindSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="QNH (hPa):"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding Qnh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Altimeter setting in hPa (e.g. 1013)"/>
                        </Grid>
                    </GroupBox>

                    <!-- Performance -->
                    <GroupBox Header="Aircraft Performance">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="TAS (kt):"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding Tas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="Level:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding Level, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Cruise altitude in feet (e.g. 1000)"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="Var (°E):"
                                   ToolTip="Magnetic variation — positive = East. Netherlands ≈ 2.5°E"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2,0,2"
                                     Text="{Binding MagneticVariation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Magnetic variation. Positive = East. Netherlands ≈ 2.5"/>
                        </Grid>
                    </GroupBox>

                    <!-- Tip -->
                    <TextBlock Text="Click map to add waypoints&#10;Right-click pin to remove"
                               Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="10" Margin="4,0,0,4" TextWrapping="Wrap"/>

                    <!-- Airport finder -->
                    <DockPanel Margin="0,4,0,0">
                        <Label Content="Find:" DockPanel.Dock="Left" VerticalAlignment="Center" Padding="0,0,4,0"/>
                        <Button Content="→" DockPanel.Dock="Right" Width="28"
                                Click="FindAirportButton_Click"
                                ToolTip="Find airport on map"/>
                        <TextBox x:Name="AirportSearchBox" Margin="0,0,4,0"
                                 CharacterCasing="Upper"
                                 ToolTip="Type ICAO code (e.g. EHTE) and press Enter"
                                 KeyDown="AirportSearchBox_KeyDown"/>
                    </DockPanel>
                    <DockPanel x:Name="AirportResultPanel" Margin="0,2,0,8"
                               Visibility="Collapsed">
                        <Button x:Name="SetDepFromFindButton" DockPanel.Dock="Right"
                                Content="Set as Dep." FontSize="10" Padding="4,1"
                                Background="#FF3F3F3F" BorderBrush="#FF3F3F3F"
                                Click="SetDepFromFind_Click"/>
                        <TextBlock x:Name="AirportResultLabel"
                                   FontSize="10" Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                    </DockPanel>

                    <!-- Map type -->
                    <DockPanel Margin="0,0,0,8">
                        <Label Content="Map:" DockPanel.Dock="Left" VerticalAlignment="Center" Padding="0,0,4,0"/>
                        <ComboBox x:Name="MapTypeCombo"
                                  SelectionChanged="MapTypeCombo_SelectionChanged">
                            <ComboBoxItem Content="Street" IsSelected="True"/>
                            <ComboBoxItem Content="Satellite"/>
                        </ComboBox>
                    </DockPanel>

                    <!-- Action buttons -->
                    <UniformGrid Columns="2" Margin="0,0,0,4">
                        <Button Content="Calculate" Command="{Binding CalculateCommand}"  Margin="0,0,4,4"/>
                        <Button Content="Clear"     Command="{Binding ClearCommand}"      Margin="0,0,0,4"
                                Background="#FF3F3F3F" BorderBrush="#FF3F3F3F"/>
                        <Button Content="Open…"     x:Name="OpenButton" Click="OpenButton_Click" Margin="0,0,4,4"
                                Background="#FF3F3F3F" BorderBrush="#FF3F3F3F"/>
                        <Button Content="Save .txt" Command="{Binding SaveCommand}"       Margin="0,0,0,4"/>
                    </UniformGrid>
                    <DockPanel Margin="0,0,0,4">
                        <CheckBox x:Name="PrintChartCheckBox" Content="Print chart"
                                  IsChecked="True" VerticalAlignment="Center"
                                  Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,8,0" DockPanel.Dock="Left"/>
                        <Button Content="Print" Click="PrintButton_Click"/>
                    </DockPanel>
                    <Button Content="RT Calls" Click="RtButton_Click" Margin="0,0,0,4"
                            ToolTip="Show radio telephony calls for this flight"/>
                    <Button Content="Dep. Airport…" Click="DepAirportButton_Click" Margin="0,0,0,4"
                            Background="#FF3F3F3F" BorderBrush="#FF3F3F3F"
                            ToolTip="Change the fixed departure airport (name and coordinates)"/>

                </StackPanel>
            </ScrollViewer>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Map -->
            <mapsui:MapControl x:Name="MapControl" Grid.Column="2"/>

        </Grid>
    </DockPanel>
</Window>
